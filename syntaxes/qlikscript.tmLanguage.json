{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Qlik Script",
  "scopeName": "source.qvs",
  "fileTypes": ["qvs"],
  "patterns": [
    { "include": "#section-marker" },
    { "include": "#block-comment" },
    { "include": "#line-comment" },
    { "include": "#rem-comment" },
    { "include": "#string" },
    { "include": "#dollar-expansion" },
    { "include": "#bracket-field" },
    { "include": "#lib-path" },
    { "include": "#control-keywords" },
    { "include": "#statement-keywords" },
    { "include": "#prefix-keywords" },
    { "include": "#clause-keywords" },
    { "include": "#logical-operators" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#number" },
    { "include": "#semicolon" }
  ],
  "repository": {

    "section-marker": {
      "comment": "///$tab Section Name — marks the start of a script section/tab",
      "match": "^(\\/\\/\\/\\$tab)(.*)$",
      "captures": {
        "1": { "name": "keyword.other.section-marker.qvs" },
        "2": { "name": "entity.name.section.qvs" }
      }
    },

    "block-comment": {
      "name": "comment.block.qvs",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.qvs" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.qvs" } }
    },

    "line-comment": {
      "name": "comment.line.double-slash.qvs",
      "match": "//.*$",
      "captures": { "0": { "name": "comment.line.double-slash.qvs" } }
    },

    "rem-comment": {
      "comment": "REM statement — treated as a comment",
      "name": "comment.line.rem.qvs",
      "match": "(?i)\\bREM\\b.*?;",
      "captures": { "0": { "name": "comment.line.rem.qvs" } }
    },

    "string": {
      "name": "string.quoted.single.qvs",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "comment": "Escaped single quote inside string",
          "name": "constant.character.escape.qvs",
          "match": "''"
        },
        { "include": "#dollar-expansion" }
      ]
    },

    "dollar-expansion": {
      "comment": "Dollar-sign expansion: $(varname) or $(#varname) or $(=expression)",
      "patterns": [
        {
          "name": "meta.dollar-expansion.qvs",
          "match": "(\\$\\()(#?)([^)]*)(\\))",
          "captures": {
            "1": { "name": "punctuation.definition.variable.qvs" },
            "2": { "name": "keyword.operator.dollar-expansion.qvs" },
            "3": { "name": "variable.other.qvs" },
            "4": { "name": "punctuation.definition.variable.qvs" }
          }
        }
      ]
    },

    "bracket-field": {
      "comment": "Bracket-quoted field/table names: [My Field Name]",
      "name": "variable.other.field.qvs",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.definition.field.begin.qvs" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.field.end.qvs" } }
    },

    "lib-path": {
      "comment": "Lib:// paths used in FROM clauses",
      "name": "string.unquoted.lib-path.qvs",
      "match": "(?i)lib://[^\\s;,)]*"
    },

    "control-keywords": {
      "comment": "Control flow statements",
      "name": "keyword.control.qvs",
      "match": "(?i)\\b(if|then|elseif|else|end\\s+if|for|for\\s+each|next|to|step|do|while|loop|until|exit|exit\\s+script|exit\\s+for|exit\\s+do|sub|end\\s+sub|call|switch|case|default|end\\s+switch|when|unless|in)\\b"
    },

    "statement-keywords": {
      "comment": "Regular script statements",
      "name": "keyword.other.statement.qvs",
      "match": "(?i)\\b(load|select|from|where|group\\s+by|order\\s+by|having|limit|union|set|let|store|into|resident|autogenerate|inline|extension|connect|to|using|map|unmap|alias|directory|execute|tag|untag|qualify|unqualify|rename\\s+field|rename\\s+fields|rename\\s+table|rename\\s+tables|drop\\s+field|drop\\s+fields|drop\\s+table|drop\\s+tables|loosen\\s+table|loosen\\s+tables|comment\\s+field|comment\\s+table|binary|nullasnull|nullasvalue|star\\s+is|force|sleep|trace|flush\\s+log|section|access|application|declare|derive|sql|sqlcolumns|sqltables|sqltypes|disconnect|field|fields|distinct|as|with|from\\s+field|from\\s+fields|format\\s+is|info|autonumber|intervalmatchwhere|noconcatenate|crosstable|hierarchy|hierarchybelongsto|generic|semantic|direct\\s+query|add\\s+only)\\b"
    },

    "prefix-keywords": {
      "comment": "Script prefixes (applied to LOAD/SELECT)",
      "name": "keyword.other.prefix.qvs",
      "match": "(?i)\\b(join|inner\\s+join|left\\s+join|right\\s+join|outer\\s+join|keep|inner\\s+keep|left\\s+keep|right\\s+keep|concatenate|noconcatenate|add|replace|merge|partial\\s+reload|first|sample|buffer|mapping|intervalmatch|crosstable|generic|semantic|hierarchy|hierarchybelongsto)\\b"
    },

    "clause-keywords": {
      "comment": "Sub-clauses and modifiers",
      "name": "keyword.other.clause.qvs",
      "match": "(?i)\\b(where|exists|not\\s+exists|only|peek|fieldvalue|fieldindex|by|asc|desc|total|all|distinct|on|resident|autogenerate|inline|extension|format\\s+is|interval\\s+match)\\b"
    },

    "logical-operators": {
      "comment": "Logical and relational operators",
      "name": "keyword.operator.logical.qvs",
      "match": "(?i)\\b(and|or|not|xor|like|match|mixmatch|wildmatch|wildmatch5|precedes|follows)\\b|<>|<=|>=|<|>|="
    },

    "functions": {
      "comment": "Built-in Qlik functions — matched before opening paren",
      "name": "support.function.qvs",
      "match": "(?i)\\b(abs|acos|acosh|addmonths|addyears|age|alt|applycodepage|applymap|argb|asin|asinh|atan|atan2|atanh|attribute|author|autonumber|autonumberhash128|autonumberhash256|avg|betadensity|betadist|betainv|binomdist|binomfrequency|binominv|bitcount|blackandschole|calcdim|capitalize|ceil|chi2test_chi2|chi2test_df|chi2test_p|chidensity|chidist|chiinv|chr|class|clientplatform|coalesce|combin|computername|concat|connectstring|converttolocaltime|correl|cos|cosh|count|countregex|day|daylightsaving|dayend|dayname|daynumberofquarter|daynumberofyear|daystart|div|documentname|documentpath|documenttitle|dual|e|emptyisnull|engineversion|evaluate|even|exists|exp|extractregex|extractregexgroup|fabs|fact|fdensity|fdist|fieldindex|fieldname|fieldnumber|fieldvalue|fieldvaluecount|filebasename|filedir|fileextension|filename|filepath|filesize|filetime|finv|findoneofvalue|firstsortedvalue|firstvalue|firstworkdate|floor|fmod|frac|fractile|fractileexc|fv|gammadensity|gammadist|gammainv|geoaggrgeometry|geoboundingbox|geocountvertex|geogetboundingbox|geogetpolygoncenter|geoinvprojectgeometry|geomakepoint|geoproject|geoprojectgeometry|georeducegeometry|getcollationlocale|getfolderpath|getobjectfield|getregistrystring|getsysattr|getuserattr|gmt|groupdimensionindex|groupdimensionlabel|hash128|hash160|hash256|hour|hrank|hsl|if|inday|indaytotime|index|indexregex|indexregexgroup|inlunarweek|inlunarweektodate|inmonth|inmonths|inmonthstodate|inmonthtodate|inobject|inquarter|inquartertodate|inweek|inweektodate|inyear|inyeartodate|interval|irr|isempty|isjson|isnull|isnum|ispartialreload|isregex|istext|isvalidcolor|iterno|jsonget|jsonset|jsonsetex|keepchar|kmeans2d|kmeanscentroid2d|kmeanscentroidnd|kmeansnd|kurtosis|lastvalue|lastworkdate|left|len|levenshteindist|linest_b|linest_df|linest_f|linest_m|linest_r2|linest_seb|linest_sem|linest_sey|linest_ssreg|linest_ssresid|localtime|log|log10|lookup|lower|ltrim|lunarweekend|lunarweekname|lunarweekstart|makedate|makeweekdate|maketime|mapsubstring|match|matchregex|max|maxstring|median|mid|min|minstring|missingcount|minute|mixmatch|mod|mode|money|month|monthend|monthname|monthsend|monthsname|monthsstart|monthstart|msgbox|mutualinfo|networkdays|nooffields|noofrows|normdist|norminv|now|nper|npv|null|nullcount|num|numericcount|objectid|odd|only|ord|osuser|peek|permut|pi|pick|pmt|poissondist|poissonfrequency|poissoninv|pow|previous|productversion|purgechar|pv|qvdcreatetime|qvdfieldname|qvdnooffields|qvdnoofrecords|qvdtablename|quarterend|quartername|quarterstart|rand|rank|rangeapp|rangeavg|rangecount|rangecorrel|rangefractile|rangeirr|rangekurtosis|rangemax|rangemaxstring|rangemin|rangeminstring|rangemissingcount|rangemode|rangenullcount|rangenumericcount|rangenpv|rangeonly|rangeskew|rangestdev|rangesum|rangetextcount|rangexirr|rangexnpv|rate|recno|reloadtime|rem|repeat|replace|replaceregex|replaceregexgroup|rgb|right|round|rowno|rtrim|second|setdateyear|setdateyearmonth|sign|sin|sinh|skew|sqrt|statename|stdev|sterr|steyx|stl_residual|stl_seasonal|stl_trend|subfield|subfieldregex|substringcount|sum|tan|tanh|tdensity|tdist|text|textbetween|textcount|time|timestamp|tinv|timezone|today|trim|ttest1_conf|ttest1_df|ttest1_dif|ttest1_lower|ttest1_sig|ttest1_sterr|ttest1_t|ttest1_upper|ttest1w_conf|ttest1w_df|ttest1w_dif|ttest1w_lower|ttest1w_sig|ttest1w_sterr|ttest1w_t|ttest1w_upper|ttest_conf|ttest_df|ttest_dif|ttest_lower|ttest_sig|ttest_sterr|ttest_t|ttest_upper|ttestw_conf|ttestw_df|ttestw_dif|ttestw_lower|ttestw_sig|ttestw_sterr|ttestw_t|ttestw_upper|upper|utc|variance|week|weekday|weekend|weekname|weekstart|weekyear|wildmatch|wildmatch5|window|wrank|xirr|xnpv|year|yearend|yearname|yearstart|yeartodate|ztest_conf|ztest_dif|ztest_lower|ztest_sig|ztest_sterr|ztest_upper|ztest_z|ztestw_conf|ztestw_dif|ztestw_lower|ztestw_sig|ztestw_sterr|ztestw_upper|ztestw_z|date#|interval#|money#|num#|time#|timestamp#)(?=\\s*\\()",
      "captures": {
        "1": { "name": "support.function.qvs" }
      }
    },

    "constants": {
      "comment": "Boolean and null constants",
      "name": "constant.language.qvs",
      "match": "(?i)\\b(true|false|null|nan)\\b"
    },

    "number": {
      "comment": "Numeric literals (integer, decimal, scientific notation, hex)",
      "name": "constant.numeric.qvs",
      "match": "\\b(0x[0-9a-fA-F]+|\\d+\\.?\\d*([eE][+-]?\\d+)?)\\b"
    },

    "semicolon": {
      "comment": "Statement terminator",
      "name": "punctuation.terminator.statement.qvs",
      "match": ";"
    }
  }
}
